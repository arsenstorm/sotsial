{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "sotsial-api",
  "account_id": "8dd0864e5cce87fba700990f062744f0",
  "main": "src/index.ts",
  "compatibility_date": "2026-04-24",
  "compatibility_flags": ["nodejs_compat"],
  "observability": {
    "enabled": true,
    "head_sampling_rate": 1,
    "logs": {
      "enabled": true
    }
  },
  "routes": [
    {
      "pattern": "https://api.sotsial.com/*",
      "zone_name": "sotsial.com",
      "custom_domain": false
    },
    {
      "pattern": "api.sotsial.com",
      "zone_name": "sotsial.com",
      "custom_domain": true
    }
  ],
  "vars": {
    "APP_BASE_URL": "http://localhost:3000",
    "AUTH_URL": "http://localhost:3000",
    "ENVIRONMENT": "development"
  },
  "env": {
    "production": {
      "vars": {
        "APP_BASE_URL": "https://api.sotsial.com",
        "AUTH_URL": "https://sotsial.com",
        "ENVIRONMENT": "production"
      }
    }
  },
  "hyperdrive": [
    {
      "binding": "DATABASE",
      "id": "REPLACE_WITH_HYPERDRIVE_ID",
      "localConnectionString": "postgresql://postgres:postgres@127.0.0.1:6432/sotsial"
    }
  ]
}
